<Window x:Class="zd2_KachalinSemen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zd2_KachalinSemen"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="600">
    <Grid Margin="0,0,2,0">
        <Menu
    Width="590" VerticalAlignment="Top" Height="25" HorizontalAlignment="Left">
            <MenuItem Header="Файл">
                <MenuItem Header="Сохранить в файл" Click="Button_Click_1"></MenuItem>
                <MenuItem Header="Загрузить из файла" Click="Button_Click"></MenuItem>
            </MenuItem>
        </Menu>
        <DataGrid x:Name="datagrid1" HorizontalAlignment="Left" Height="235" VerticalAlignment="Top" Width="300" Margin ="276,63,0,0"/>
        <Label Content="Телефоная книга" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.263,0.577" Margin ="376,37,0,0"/>
        <TextBox x:Name="SearchName" HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="220"  Margin ="315,342,0,0"/>
        <Label Content="Введите имя" HorizontalAlignment="Left" VerticalAlignment="Top" Margin ="376,316,0,0"/>
        <Button Content="Добавить" HorizontalAlignment="Left" VerticalAlignment="Top" Width="90" Height="30" Click="Button_Click_4" Margin ="150,260,0,0"/>
        <TextBox x:Name="NameAdded" HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="200"  Margin ="50,162,0,0"/>
        <TextBox x:Name="PhoneAdded" HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="200" Margin ="50,222,0,0"/>
        <Label Content="Phone" HorizontalAlignment="Left" VerticalAlignment="Top"  Margin ="128,191,0,0"/>
        <Label Content="Name" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="-0.071,0.5" Margin ="128,131,0,0"/>
        <Button Content="Найти" HorizontalAlignment="Left" VerticalAlignment="Top" Width="65" Height="23" Click="Button_Click_2" Margin ="390,370,0,0" RenderTransformOrigin="0.615,1.217"/>
        <Button Content="Удалить" HorizontalAlignment="Left" VerticalAlignment="Top" Width="95" Height="30" Click="Button_Click_3" Margin ="50,260,0,0"/>
    </Grid>

</Window>
