<Window x:Class="zd2_KachalinSemen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:zd2_KachalinSemen"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="600">
    <Grid Margin="0,0,2,0">
        <Menu
    Width="590" VerticalAlignment="Top" Height="25" HorizontalAlignment="Left">
            <MenuItem Header="Файл">
                <MenuItem Header="Сохранить в файл" Click="Button_Click_1"></MenuItem>
                <MenuItem Header="Загрузить из файла" Click="Button_Click"></MenuItem>
            </MenuItem>
            <MenuItem Header="Контакты">
                <MenuItem Header="1.Удаление из таблицы" Click="Button_Click_3"></MenuItem>
                <MenuItem Header="1.Добавление в таблицу" Click="Button_Click_4"></MenuItem>
                <MenuItem Header="2.Удаление из таблицы" Click="Button_Click_32"></MenuItem>
                <MenuItem Header="2.Добавление в таблицу" Click="Button_Click_42"></MenuItem>
                <MenuItem Header="Поиск по имени" Click="Button_Click_2"></MenuItem>
            </MenuItem>
            <MenuItem Header="Программа">
                <MenuItem Header="Выйти" Click="ExitButton_Click_3"></MenuItem>
            </MenuItem>
        </Menu>
        <DataGrid x:Name="datagrid1" HorizontalAlignment="Left" Height="235" VerticalAlignment="Top" Width="300" Margin ="276,63,0,0"/>
        <Label Content="Телефоная книга" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.263,0.577" Margin ="376,37,0,0"/>
        <TextBox x:Name="SearchName" HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="220"  Margin ="317,356,0,0"/>
        <Label Content="Введите имя для поиска" HorizontalAlignment="Left" VerticalAlignment="Top" Margin ="352,330,0,0" RenderTransformOrigin="0.343,0.538"/>
        <TextBox x:Name="NameAdded" HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="200"  Margin ="32,130,0,0"/>
        <TextBox x:Name="PhoneAdded" HorizontalAlignment="Left" Height="23" TextWrapping="Wrap" VerticalAlignment="Top" Width="200" Margin ="32,190,0,0"/>
        <Label Content="Phone" HorizontalAlignment="Left" VerticalAlignment="Top"  Margin ="110,159,0,0"/>
        <Label Content="Name" HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="-0.071,0.5" Margin ="110,99,0,0">
            <Label.RenderTransform>
                <TransformGroup>
                    <ScaleTransform/>
                    <SkewTransform/>
                    <RotateTransform Angle="-1.762"/>
                    <TranslateTransform/>
                </TransformGroup>
            </Label.RenderTransform>
        </Label>
    </Grid>

</Window>
